{
  "manifest_version": 2,
  "name": "TrustLayer",
  "version": "3.1.0",
  "description": "Overlay trust signals on AI-generated content. See confidence scores, hedge detection, and verification suggestions.",
  "author": "TrustLayer",
  "browser_action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "TrustLayer v3"
  },
  "background": {
    "scripts": ["utils/constants.js", "utils/storage.js", "background/analyzer.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://copilot.microsoft.com/*",
        "*://www.bing.com/chat*",
        "*://copilot.bing.com/*"
      ],
      "js": [
        "utils/constants.js",
        "utils/storage.js",
        "content/cache.js",
        "content/detector.js",
        "content/badge.js",
        "content/panel.js",
        "content/confirmer.js",
        "content/injector.js"
      ],
      "css": ["styles/trustlayer.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://perplexity.ai/*",
    "*://copilot.microsoft.com/*",
    "*://www.bing.com/chat*",
    "*://copilot.bing.com/*",
    "*://generativelanguage.googleapis.com/*",
    "*://api.openai.com/*",
    "*://api.anthropic.com/*"
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src https://generativelanguage.googleapis.com https://api.openai.com https://api.anthropic.com; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com",
  "web_accessible_resources": ["styles/trustlayer.css"]
}